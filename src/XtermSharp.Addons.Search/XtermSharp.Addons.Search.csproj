<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>XtermSharp.Addons.Search</RootNamespace>
    <AssemblyName>XtermSharp.Addons.Search</AssemblyName>
    <PackageId>XtermSharp.Addons.Search</PackageId>
    <Version>0.1.0-alpha.1</Version>
    <Description>Search addon for XtermSharp.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/xterm-sharp/xterm-sharp</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../XtermSharp/XtermSharp.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="XtermSharp" />
    <Using Include="XtermSharp.Addons" />
    <Using Include="XtermSharp.Decorations" />
    <Using Include="XtermSharp.Events" />
    <Using Include="XtermSharp.Logging" />
    <Using Include="XtermSharp.Selection" />
    <Using Include="XtermSharp.Snapshots" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>XtermSharp.Addons.Search.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
    <None Include="../../NOTICE.md" Pack="true" PackagePath="/" />
    <None Include="../../LICENSE" Pack="true" PackagePath="/" />
    <None Include="../../docs/search-addon.md" Pack="true" PackagePath="docs/" />
  </ItemGroup>
</Project>
