<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="XtermSharp.WinUI.Demo.SSH.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:terminal="using:XtermSharp.WinUI.Controls"
    Loaded="Page_Loaded"
    SizeChanged="Page_SizeChanged"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton x:Name="ConnectButton"
                          AutomationProperties.Name="Connect to SSH server"
                          Click="ConnectButton_Click"
                          Label="Connect">
                <AppBarButton.Icon>
                    <SymbolIcon x:Name="ConnectIcon" Symbol="Play" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:Name="CopyButton"
                          AutomationProperties.Name="Copy terminal selection"
                          Click="CopyButton_Click"
                          IsEnabled="False"
                          Label="Copy">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Copy" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton AutomationProperties.Name="Paste clipboard text"
                          Click="PasteButton_Click"
                          Label="Paste">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Paste" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton AutomationProperties.Name="Clear terminal display"
                          Click="ClearButton_Click"
                          Label="Clear">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Clear" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Expander x:Name="ConnectionExpander"
                  Grid.Row="1"
                  Header="Connection"
                  IsExpanded="True"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  SizeChanged="ConnectionExpander_SizeChanged">
            <ScrollViewer x:Name="ConnectionScroller"
                          MaxHeight="360"
                          HorizontalContentAlignment="Stretch"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Grid x:Name="ConnectionGrid"
                      Padding="12,4,12,12"
                      ColumnSpacing="12"
                      RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="HostTextBox"
                             Grid.Row="0"
                             Grid.Column="0"
                             Grid.ColumnSpan="4"
                             AutomationProperties.Name="SSH host"
                             Header="Host" />
                    <NumberBox x:Name="PortNumberBox"
                               Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               AutomationProperties.Name="SSH port"
                               Header="Port"
                               Maximum="65535"
                               Minimum="1"
                               SpinButtonPlacementMode="Compact" />
                    <TextBox x:Name="UsernameTextBox"
                             Grid.Row="1"
                             Grid.Column="2"
                             Grid.ColumnSpan="2"
                             AutomationProperties.Name="SSH username"
                             Header="Username" />
                    <ComboBox x:Name="AuthenticationComboBox"
                              Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="4"
                              AutomationProperties.Name="Authentication method"
                              Header="Authentication"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="AuthenticationComboBox_SelectionChanged">
                        <ComboBoxItem Content="Password" />
                        <ComboBoxItem Content="Private key" />
                    </ComboBox>

                    <Grid x:Name="PasswordPanel"
                          Grid.Row="3"
                          Grid.Column="0"
                          Grid.ColumnSpan="4"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="PasswordBox"
                                     AutomationProperties.Name="SSH password"
                                     Header="Password" />
                        <TextBox x:Name="PasswordTerminalTypeTextBox"
                                 Grid.Column="1"
                                 AutomationProperties.Name="Remote terminal type"
                                 Header="Terminal type" />
                    </Grid>

                    <Grid x:Name="PrivateKeyPanel"
                          Grid.Row="3"
                          Grid.Column="0"
                          Grid.ColumnSpan="4"
                          ColumnSpacing="8"
                          RowSpacing="8"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="PrivateKeyTextBox"
                                 Grid.ColumnSpan="2"
                                 AutomationProperties.Name="Private key path"
                                 Header="Private key" />
                        <Button x:Name="BrowsePrivateKeyButton"
                                Grid.Column="2"
                                Margin="0,24,0,0"
                                AutomationProperties.Name="Browse for SSH private key"
                                Click="BrowsePrivateKeyButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="OpenFile" />
                                <TextBlock Text="Browse" />
                            </StackPanel>
                        </Button>
                        <PasswordBox x:Name="PrivateKeyPassphraseBox"
                                     Grid.Row="1"
                                     AutomationProperties.Name="Private key passphrase"
                                     Header="Passphrase" />
                        <TextBox x:Name="KeyTerminalTypeTextBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 AutomationProperties.Name="Remote terminal type"
                                 Header="Terminal type" />
                    </Grid>

                    <Grid x:Name="HostKeyPanel"
                          Grid.Row="4"
                          Grid.Column="0"
                          Grid.ColumnSpan="4"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HostKeyTextBox"
                                 AutomationProperties.Name="Trusted SHA-256 host key"
                                 Header="Trusted host key"
                                 PlaceholderText="SHA256:..." />
                        <CheckBox x:Name="AcceptAnyHostKeyCheckBox"
                                  Grid.Column="1"
                                  Margin="0,24,0,0"
                                  AutomationProperties.HelpText="Unsafe. Use only with disposable local test servers."
                                  Content="Trust any key"
                                  ToolTipService.ToolTip="Unsafe. Use only with disposable local test servers." />
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Expander>

        <terminal:TerminalView x:Name="TerminalView"
                               Grid.Row="2"
                               Padding="12"
                               AutomationProperties.Name="SSH terminal session"
                               SelectionChanged="TerminalView_SelectionChanged" />

        <InfoBar x:Name="StatusInfoBar"
                 Grid.Row="3"
                 Margin="8"
                 AutomationProperties.LiveSetting="Polite"
                 IsClosable="False"
                 IsOpen="True"
                 Message="Disconnected. Enter connection details and connect."
                 Severity="Informational" />
    </Grid>
</Page>
