<Window x:Class="XtermSharp.Wpf.Demo.SSH.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:XtermSharp.Wpf.Controls;assembly=XtermSharp.Wpf"
        Title="XtermSharp WPF SSH Demo"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="560"
        Background="{StaticResource AppSurfaceBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16,12"
                Background="{StaticResource RaisedSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="124" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <Label Target="{Binding ElementName=HostTextBox}" Content="Host" />
                    <TextBox x:Name="HostTextBox" AutomationProperties.Name="SSH host" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <Label Target="{Binding ElementName=PortTextBox}" Content="Port" />
                    <TextBox x:Name="PortTextBox" AutomationProperties.Name="SSH port" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4">
                    <Label Target="{Binding ElementName=UsernameTextBox}" Content="Username" />
                    <TextBox x:Name="UsernameTextBox" AutomationProperties.Name="SSH username" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="6">
                    <Label Target="{Binding ElementName=AuthenticationComboBox}" Content="Authentication" />
                    <ComboBox x:Name="AuthenticationComboBox"
                              AutomationProperties.Name="Authentication method"
                              SelectionChanged="AuthenticationComboBox_SelectionChanged">
                        <ComboBoxItem Content="Password" />
                        <ComboBoxItem Content="Private key" />
                    </ComboBox>
                </StackPanel>
                <Button x:Name="ConnectButton"
                        Grid.Row="0"
                        Grid.Column="8"
                        Margin="0,20,0,0"
                        Content="Connect"
                        IsDefault="True"
                        AutomationProperties.Name="Connect to SSH server"
                        Click="ConnectButton_Click" />

                <Grid x:Name="PasswordPanel" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Target="{Binding ElementName=PasswordBox}" Content="Password" />
                        <PasswordBox x:Name="PasswordBox" AutomationProperties.Name="SSH password" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Target="{Binding ElementName=PasswordTerminalTypeTextBox}" Content="Terminal type" />
                        <TextBox x:Name="PasswordTerminalTypeTextBox" AutomationProperties.Name="Remote terminal type" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="PrivateKeyPanel"
                      Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="5"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Target="{Binding ElementName=PrivateKeyTextBox}" Content="Private key" />
                        <TextBox x:Name="PrivateKeyTextBox" AutomationProperties.Name="Private key path" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Margin="0,20,0,0"
                            Content="Browse..."
                            AutomationProperties.Name="Browse for SSH private key"
                            Click="BrowsePrivateKeyButton_Click" />
                    <StackPanel Grid.Column="4">
                        <Label Target="{Binding ElementName=PrivateKeyPassphraseBox}" Content="Passphrase" />
                        <PasswordBox x:Name="PrivateKeyPassphraseBox" AutomationProperties.Name="Private key passphrase" />
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <Label Target="{Binding ElementName=KeyTerminalTypeTextBox}" Content="Terminal type" />
                        <TextBox x:Name="KeyTerminalTypeTextBox" AutomationProperties.Name="Remote terminal type" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Grid.Column="6" Grid.ColumnSpan="3">
                    <Label Target="{Binding ElementName=HostKeyTextBox}" Content="Trusted host key (SHA-256)" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HostKeyTextBox" AutomationProperties.Name="Trusted SHA-256 host key" />
                        <CheckBox x:Name="AcceptAnyHostKeyCheckBox"
                                  Grid.Column="2"
                                  Content="Skip verification"
                                  AutomationProperties.HelpText="Unsafe. Use only with disposable local test servers." />
                    </Grid>
                    <Label Target="{Binding ElementName=RenderingModeComboBox}" Content="Rendering mode" />
                    <ComboBox x:Name="RenderingModeComboBox"
                              AutomationProperties.Name="Rendering mode"
                              SelectionChanged="RenderingModeComboBox_SelectionChanged" />
                </StackPanel>
            </Grid>
        </Border>

        <wpf:TerminalView x:Name="TerminalView"
                          Grid.Row="1"
                          Padding="12"
                          ShowRenderingDebugOverlay="True"
                          AutomationProperties.Name="SSH terminal session" />

        <Border Grid.Row="2"
                Padding="12,0"
                Background="{StaticResource RaisedSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="True">
                <Ellipse x:Name="StatusIndicator"
                         Width="8"
                         Height="8"
                         Margin="0,0,8,0"
                         Fill="{StaticResource SecondaryTextBrush}" />
                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Disconnected. Enter connection details and connect."
                           TextTrimming="CharacterEllipsis"
                           AutomationProperties.LiveSetting="Polite" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
