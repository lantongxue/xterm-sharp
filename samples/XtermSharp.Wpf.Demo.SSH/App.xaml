<Application x:Class="XtermSharp.Wpf.Demo.SSH.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#171A1F" />
        <SolidColorBrush x:Key="RaisedSurfaceBrush" Color="#20242B" />
        <SolidColorBrush x:Key="FieldSurfaceBrush" Color="#111419" />
        <SolidColorBrush x:Key="BorderBrush" Color="#414852" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B7BEC8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F81F7" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#4AC26B" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF7B72" />

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,0,0,4" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Foreground" Value="#15181C" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Application.Resources>
</Application>
